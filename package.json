{
  "name": "team-collab-system",
  "version": "0.1.0",
  "description": "Multi-Agent Team Collaboration System with hierarchical roles and real-time dashboard",
  "type": "module",
  "main": "dist/core/orchestrator.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server/index.ts",
    "demo": "tsx src/demo.ts",
    "start": "node dist/server/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "nanoid": "^5.0.9",
    "simple-git": "^3.27.0",
    "socket.io": "^4.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
